{
    "name": "lexbor/lexbor-php",
    "description": "Zero-runtime-dependency userland PHP port of Lexbor.",
    "type": "library",
    "license": "BSD-2-Clause",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Lexbor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lexbor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}

